{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "checkJs": true,
    "experimentalDecorators": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true
  },
  "exclude": ["node_modules", "**/node_modules/*"]
}
